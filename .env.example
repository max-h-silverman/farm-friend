# Local development env vars for the Firebase emulator suite.
# In deployed environments these come from `.env.<project>` + `firebase
# functions:secrets`. See CLAUDE.md → "Project Constitution" (provider-preference
# order) and "Stack → LLM" for the model strategy; `app/config.py:load_settings`
# is the source of truth for the LLM_PROVIDER values below.

# --- LLM provider selection ---
# LLM_PROVIDER picks the adapter + sensible model/URL defaults. Values:
#   mistral-deepinfra  Mistral Small 3.2 (24B) on DeepInfra. CODE DEFAULT.
#   olmo               Self-hosted OLMo on a local vLLM/SGLang endpoint. OLMo is
#                      the constitution's ethical benchmark but is NOT currently
#                      served by any hosted provider (self-host only).
#   olmo-openrouter    Wired but NON-FUNCTIONAL right now — OpenRouter has no live
#                      endpoint for the OLMo instruct slug (a call 404s). Do not use.
#   openai-compatible  Any OpenAI-compatible endpoint; set LLM_BASE_URL + models.
#   anthropic          Claude (Sonnet 4.6) fallback; needs ANTHROPIC_API_KEY.
#
# Each provider resolves its own base URL and model ids — you only need to set
# the ones below to override a default. For the code default (mistral-deepinfra)
# just set LLM_API_KEY to your DeepInfra key.
LLM_PROVIDER=mistral-deepinfra
LLM_API_KEY=your-deepinfra-key
# LLM_MODEL=               # override the strong-tier model id
# LLM_CLASSIFIER_MODEL=    # override the fast-tier model id
# LLM_BASE_URL=            # required only for olmo (self-host) / openai-compatible
LLM_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.1

# Self-hosted OLMo (the constitution's ethical benchmark — the only way to run it
# today; no hosted provider currently serves an OLMo instruct model):
# LLM_PROVIDER=olmo
# LLM_BASE_URL=http://localhost:8000/v1   # your local vLLM/SGLang endpoint

# Anthropic fallback:
# LLM_PROVIDER=anthropic
# ANTHROPIC_API_KEY=sk-ant-...

# Generic OpenAI-compatible hosted provider or self-hosted vLLM/SGLang:
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.provider.example/v1
# LLM_MODEL=provider/model-large
# LLM_CLASSIFIER_MODEL=provider/model-small

# Telnyx
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_FROM_NUMBER=+15555550100

# Public URL for the vCard (served by Firebase Hosting)
VCARD_URL=https://farm-friend.web.app/farmfriend.vcf

# Optional Firebase Storage bucket for persisted inbound MMS photos.
# Defaults to ${GOOGLE_CLOUD_PROJECT}.appspot.com in deployed functions.
# MMS_MEDIA_BUCKET=farm-friend-vashon.appspot.com

# Coordinator phone — used for immediate escalation alerts (injury/safety).
# Unset means urgent escalations are flagged but NOT texted in real time.
COORDINATOR_PHONE=+12065550100
