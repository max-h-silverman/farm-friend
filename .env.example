# Farm Friend — environment (copy to .env; .env is gitignored)

# Postgres / Neon — required for migrations + integration tests
DATABASE_URL=postgres://user:pass@localhost:5432/farmfriend

# LLM provider — "stub" (default in tests/evals) or "openweight"
LLM_PROVIDER=stub
LLM_MODEL=

# SMS provider — "simulator" (default in tests) or "telnyx"
SMS_PROVIDER=simulator
TELNYX_API_KEY=
TELNYX_MESSAGING_PROFILE_ID=
TELNYX_FROM_NUMBER=

# Map provider — "stub" (offline, default in tests/evals/importer) or a live geocoder
MAP_PROVIDER=stub

# Privacy — salt for phone hashing (never commit a real value)
PHONE_HASH_SALT=dev-only-change-me

# Auth — email magic links (F-006c)
MAGIC_LINK_SECRET=dev-only-change-me
