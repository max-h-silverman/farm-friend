# Local development env vars for the Firebase emulator suite.
# In deployed environments these come from `firebase functions:secrets`.

# LLM provider — olmo | openai-compatible | anthropic
# Default open-model path: Ai2 OLMo served by a local or hosted
# OpenAI-compatible endpoint such as vLLM or SGLang.
LLM_PROVIDER=olmo
LLM_BASE_URL=http://localhost:8000/v1
LLM_API_KEY=local-or-provider-key
LLM_MODEL=allenai/Olmo-3.1-32B-Instruct
LLM_CLASSIFIER_MODEL=allenai/Olmo-3-7B-Instruct
LLM_TIMEOUT_MS=20000
LLM_TEMPERATURE=0.1

# Optional Anthropic fallback
# LLM_PROVIDER=anthropic
# LLM_MODEL_FAST=claude-haiku-4-5-20251001
# LLM_MODEL_STRONG=claude-sonnet-4-6
# ANTHROPIC_API_KEY=sk-ant-...

# Optional generic OpenAI-compatible hosted provider
# LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=https://api.provider.example/v1
# LLM_MODEL_STRONG=provider/model-large
# LLM_MODEL_FAST=provider/model-small

# Telnyx
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_FROM_NUMBER=+15555550100

# Public URL for the vCard (served by Firebase Hosting)
VCARD_URL=https://farm-friend.web.app/farmfriend.vcf

# Optional Firebase Storage bucket for persisted inbound MMS photos.
# Defaults to ${GOOGLE_CLOUD_PROJECT}.appspot.com in deployed functions.
# MMS_MEDIA_BUCKET=farm-friend-vashon.appspot.com

# Coordinator phone (Max) — used for escalation alerts
COORDINATOR_PHONE=+12065550100

# Reply classifier confidence threshold for auto-reply (0.0–1.0)
CLASSIFIER_CONFIDENCE_THRESHOLD=0.75
