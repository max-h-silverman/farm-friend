# Local development env vars for the Firebase emulator suite.
# In deployed environments these come from `firebase functions:secrets`.

# LLM provider — anthropic | openai-compatible
LLM_PROVIDER=anthropic
LLM_MODEL_FAST=claude-haiku-4-5-20251001
LLM_MODEL_STRONG=claude-sonnet-4-6

# Required for anthropic provider
ANTHROPIC_API_KEY=sk-ant-...

# Required if LLM_PROVIDER=openai-compatible
# LLM_BASE_URL=http://localhost:8000/v1
# LLM_API_KEY=...

# Telnyx
TELNYX_API_KEY=KEY...
TELNYX_PUBLIC_KEY=...
TELNYX_FROM_NUMBER=+15555550100

# Public URL for the vCard (served by Firebase Hosting)
VCARD_URL=https://farm-friend.web.app/farmfriend.vcf

# Coordinator phone (Max) — used for escalation alerts
COORDINATOR_PHONE=+12065550100

# Reply classifier confidence threshold for auto-reply (0.0–1.0)
CLASSIFIER_CONFIDENCE_THRESHOLD=0.75
